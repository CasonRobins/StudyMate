<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="400.0" prefWidth="600.0" spacing="10.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.westga.comp2320.studymate.controller.StudyMateController">

    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
   <MenuBar>
     <menus>
       <Menu mnemonicParsing="false" text="File">
            <items>
               <MenuItem fx:id="saveMenuItem" mnemonicParsing="false" text="Save" />
            </items>
       </Menu>
     </menus>
   </MenuBar>

    <Label text="Day of week:" />
   <HBox prefHeight="100.0" prefWidth="200.0">
      <children>
         <RadioButton fx:id="mondayRadio" mnemonicParsing="false" text="M">
            <toggleGroup>
               <ToggleGroup fx:id="dayGroup" />
            </toggleGroup>
         </RadioButton>
         <RadioButton fx:id="tuesdayRadio" mnemonicParsing="false" text="T" toggleGroup="$dayGroup" />
         <RadioButton fx:id="wednesdayRadio" mnemonicParsing="false" text="W" toggleGroup="$dayGroup" />
         <RadioButton fx:id="thursdayRadio" mnemonicParsing="false" text="R" toggleGroup="$dayGroup" />
         <RadioButton fx:id="fridayRadio" mnemonicParsing="false" text="F" toggleGroup="$dayGroup" />
      </children>
   </HBox>

    <Label text="Subject:" />
   <HBox prefHeight="100.0" prefWidth="200.0">
      <children>
         <CheckBox fx:id="englCheck" mnemonicParsing="false" text="ENGL" />
         <CheckBox fx:id="histCheck" mnemonicParsing="false" text="HIST" />
         <CheckBox fx:id="mathCheck" mnemonicParsing="false" text="MATH" />
         <CheckBox fx:id="compCheck" mnemonicParsing="false" text="COMP" />
      </children>
   </HBox>
   <Label fx:id="errorLabel" textFill="RED" />

    <Label text="Task:" />
    <TextField fx:id="taskField" />

    <HBox spacing="10">
        <Button onAction="#handleAdd" text="Add" />
        <Button onAction="#handleDelete" text="Delete" />
    </HBox>

    <Label fx:id="dayError" />
    <Label fx:id="subjectError" />

    <ListView fx:id="listView" prefHeight="137.0" prefWidth="580.0" />

</VBox>
